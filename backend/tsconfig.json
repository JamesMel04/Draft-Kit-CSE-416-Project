{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,
    "esModuleInterop": true,

    "skipLibCheck": true,
    "sourceMap": true,

    "baseUrl": "./src",
    "paths": {
      "@/*": ["./*"],
      "@data/*": ["./data/*"],
      "@routes/*": ["./routes/*"],
      "@utils/*": ["./utils/*"],
      "@types/*": ["./types/*"]
    }
  }
}
